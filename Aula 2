import java.util.Scanner;

public class Atividade_2 {
    public static void main(String[] args){
        Scanner sc = new Scanner(System.in);
        
        int[] soma = new int[3];
        int i = 0;
        int adicao = 0;
        int aux = 0;
        while(i < 3){
            int valor = 0;
            aux += 1;
            System.out.println("Digite o valor " + (i+1));
            try{
                valor = sc.nextInt();
                soma[i] = valor;
                adicao += soma[i];
            } catch(Exception e) {
            System.out.println("Digite um valor numerico inteiro");
                
                sc.nextLine();
                continue;
            }
            i++;
        }
        System.out.println("O Resultado da soma é: " + adicao);
        System.out.println("A quantidade de vezes pedida foi: " + aux);
        
        }
}
